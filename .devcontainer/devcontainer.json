{
	"name": "RAG Challenge - Full Stack",
	"dockerComposeFile": [
		"../docker-compose.yml",
		"docker-compose.dev.yml"
	],
	"service": "backend",
	"workspaceFolder": "/app",

	// Shutdown all services when the dev container stops
	"shutdownAction": "stopCompose",

	// Forward ports for all services
	"forwardPorts": [
		8000,  // Backend API
		8501,  // Frontend Streamlit
		5432,  // PostgreSQL
		1433   // SQL Server
	],

	// Port attributes for better UX
	"portsAttributes": {
		"8000": {
			"label": "Backend API",
			"onAutoForward": "notify"
		},
		"8501": {
			"label": "Frontend UI",
			"onAutoForward": "openBrowser"
		},
		"5432": {
			"label": "PostgreSQL"
		},
		"1433": {
			"label": "SQL Server"
		}
	},

	// Install dependencies and run migrations after container is created
	"postCreateCommand": "bash .devcontainer/post-create.sh",

	// Validate services health on startup
	"postStartCommand": "bash .devcontainer/post-start.sh",

	// VS Code extensions to install
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-python.black-formatter",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"donjayamanne.githistory",
				"eamodio.gitlens",
				"ms-azuretools.vscode-docker"
			],
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python",
				"python.linting.enabled": true,
				"python.linting.ruffEnabled": true,
				"python.formatting.provider": "black",
				"editor.formatOnSave": true,
				"editor.codeActionsOnSave": {
					"source.organizeImports": "explicit"
				}
			}
		}
	},

	// Run as non-root user for security
	"remoteUser": "root",

	// Environment variables
	"remoteEnv": {
		"PYTHONUNBUFFERED": "1",
		"PYTHONDONTWRITEBYTECODE": "1"
	},

	// Features to add
	"features": {
		"ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	}
}
