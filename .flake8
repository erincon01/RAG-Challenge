[flake8]
# Align with pyproject.toml [tool.ruff] settings — both must agree
max-line-length = 120

# --- permanent ignores (match ruff pyproject.toml) ---
# E501: line too long — enforced by ruff formatter at 120 chars
# E203: whitespace before ':' — false positive for ruff-formatted slices (e.g. df.iloc[i : i + n])
# F821/F841/F811: pre-existing tech debt documented in pyproject.toml
extend-ignore =
    E501,
    E203,
    F821,
    F841,
    F811,

# --- per-file ignores ---
per-file-ignores =
    # sys.path manipulation required before module_* imports
    app.py: E402
    sqlserver/01_download_to_local.py: E402
    # sys.path.insert must run before importing python_modules/*
    tests/test_module_data.py: E402

# --- exclude non-production folders (match ruff pyproject.toml) ---
exclude =
    sqlserver/,
    postgres/,
    dotnetMalaga/,
    deploy/,
    backup/,
    data/,
    .git,
    __pycache__,
    .venv,
    venv,
