# Docker local environment configuration
# Copy this to .env.docker and adjust as needed

# Application
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL (Docker service)
POSTGRES_DB=rag_challenge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_local_pwd

# SQL Server (Docker service)
MSSQL_SA_PASSWORD=SqlServer_Local_Pwd123!

# Azure OpenAI (required for AI features - replace with your own keys)
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL2=gpt-4o
OPENAI_KEY=your_openai_key_here
OPENAI_ENDPOINT=https://your_endpoint.openai.azure.com/

# GitHub/StatsBomb
REPO_OWNER=statsbomb
REPO_NAME=open-data
LOCAL_FOLDER=./data

# Frontend webapp
FRONTEND_PORT=5173
VITE_BACKEND_ORIGIN=http://backend:8000
VITE_API_BASE_URL=/api/v1
