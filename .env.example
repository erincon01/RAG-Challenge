# Application Environment
# Options: local, azure, test
ENVIRONMENT=local

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# GitHub Repository (StatsBomb Open Data)
BASE_URL=https://github.com/statsbomb/open-data/raw/master/data
REPO_OWNER=statsbomb
REPO_NAME=open-data
LOCAL_FOLDER=./data

# PostgreSQL (Docker local or any PostgreSQL + pgvector)
POSTGRES_HOST=localhost
POSTGRES_DB=rag_challenge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_local_pwd

# SQL Server (Docker local or any SQL Server 2025+)
SQLSERVER_HOST=localhost
SQLSERVER_DB=rag_challenge
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=SqlServer_Local_Pwd123!

# OpenAI / Azure OpenAI
# Provider: "azure" or "openai"
OPENAI_PROVIDER=azure
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL2=gpt-4o
OPENAI_KEY=your_key
OPENAI_ENDPOINT=https://your_endpoint.openai.azure.com/

# Frontend webapp
FRONTEND_PORT=5173
VITE_BACKEND_ORIGIN=http://localhost:8000
VITE_API_BASE_URL=/api/v1
